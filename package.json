{
  "name": "pluts",
  "version": "0.1.3",
  "description": "A double-entry accounting ledger for TypeScript, targeting Cloudflare Durable Objects (SQLite-backed storage).",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamburmister/pluts.git"
  },
  "keywords": [
    "typescript",
    "accounting",
    "double-entry",
    "ledger",
    "bookkeeping",
    "cloudflare",
    "durable-objects",
    "sqlite"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "fix": "biome check --write src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "publint": "publint",
    "verify:pack": "node scripts/verify-pack.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260706.1",
    "publint": "^0.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true
  }
}
