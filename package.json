{
  "name": "pluts",
  "version": "0.1.0",
  "description": "A double-entry accounting ledger for TypeScript, targeting Cloudflare Durable Objects (SQLite-backed storage).",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamburmister/pluts.git"
  },
  "keywords": [
    "typescript",
    "accounting",
    "double-entry",
    "ledger",
    "bookkeeping",
    "cloudflare",
    "durable-objects",
    "sqlite"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "^5.20260706.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
